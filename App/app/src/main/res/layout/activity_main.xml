<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F7">

    <LinearLayout
        android:id="@+id/mainContainer"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BOTÓN PRINCIPAL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="GENERAR FORMULARIO"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:elevation="6dp"
            app:cornerRadius="16dp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#4A90E2"/>

        <!-- BOTONES SECUNDARIOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubir"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="SUBIR ARCHIVO"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:elevation="3dp"
                app:cornerRadius="12dp"
                app:backgroundTint="#6C63FF"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReportes"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="VER REPORTES"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:elevation="3dp"
                app:cornerRadius="12dp"
                app:backgroundTint="#FF7A59"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarForm"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="SAVE FORM"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:elevation="3dp"
                app:cornerRadius="12dp"
                app:backgroundTint="#00B894"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarPKM"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="SAVE PKM"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:elevation="3dp"
                app:cornerRadius="12dp"
                app:backgroundTint="#FDCB6E"/>

        </LinearLayout>

        <!-- EDITOR -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDITOR DE TEXTO"
            android:textStyle="bold"
            android:textColor="#2D3436"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="horizontal"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:layout_marginBottom="8dp">

            <!-- NUMERACIÓN -->
            <TextView
                android:id="@+id/lineNumbers"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="1"
                android:textColor="#B2BEC3"
                android:textSize="12sp"
                android:paddingEnd="10dp"/>

            <!-- EDITOR -->
            <EditText
                android:id="@+id/editor"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="top|start"
                android:background="@android:color/transparent"
                android:hint="Escribe tu código aquí..."
                android:textColor="#2D3436"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"/>
        </LinearLayout>

        <!-- VISTA PREVIA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VISTA PREVIA"
            android:textStyle="bold"
            android:textColor="#2D3436"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"/>

        <FrameLayout
            android:id="@+id/previewContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:padding="10dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>